{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string"
    },
    "Naeringsindhold": {
      "type": "text"
    },
    "ProduktBeskrivelse": {
      "type": "text"
    },
    "Pris": {
      "type": "decimal"
    },
    "Image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Slug": {
      "type": "uid",
      "targetField": "Title"
    },
    "recipes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::recipe.recipe",
      "inversedBy": "products"
    },
    "brand": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::brand.brand"
    },
    "kategorier": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::kategori.kategori",
      "mappedBy": "product"
    },
    "land": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::land.land"
    },
    "type": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::type.type"
    }
  }
}
